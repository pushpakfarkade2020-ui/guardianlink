<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F5F7FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:text="GuardianLink"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- SOS BUTTON -->
        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginBottom="10dp">

            <!-- Glow -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/sos_glow"/>

            <!-- SOS -->
            <Button
                android:id="@+id/sosBtn"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:text="SOS"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:elevation="8dp"
                android:background="@drawable/sos_circle"/>
        </FrameLayout>

        <!-- STATUS -->
        <TextView
            android:text="● Location Ready"
            android:textColor="#16A34A"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HEADER -->
            <TextView
                android:text="Emergency Contacts"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#111827"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- INPUT CONTAINER (HIDDEN INITIALLY) -->
            <LinearLayout
                android:id="@+id/inputContainer"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/nameInput"
                    android:hint="Name"
                    android:textColor="#000000"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/phoneInput"
                    android:hint="Phone Number"
                    android:textColor="#000000"
                    android:inputType="phone"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>



            <!-- ADD BUTTON -->
            <Button
                android:id="@+id/addBtn"
                android:text="Add Contact"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:elevation="6dp"
                android:background="@drawable/button_bg"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <!-- CONTACT LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:overScrollMode="never"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>